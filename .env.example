# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
VITE_PUBLIC_SUPABASE_URL=your_supabase_project_url
VITE_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# EmailJS Configuration
# Get these from your EmailJS dashboard: https://www.emailjs.com
VITE_SERVICE_ID=your_emailjs_service_id
VITE_TEMPLATE_ID=your_emailjs_template_id
VITE_TEMPLATE_ID_2=your_emailjs_second_template_id
VITE_PUBLIC_KEY=your_emailjs_public_key

# Test Configuration (for scripts/book-test-reminder.mjs)
TEST_REMINDER_EMAIL=test@example.com

# Restaurant Configuration
# Optional: Defaults to "Atlantic/Canary" if not set
RESTAURANT_TIMEZONE=Atlantic/Canary
